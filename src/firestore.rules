rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- الدوال المساعدة (Helper Functions) ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == "70vVkvBj0IQIwbxwdPaEAOj6LSu2" || 
        request.auth.token.email == "mhmdsulimn.dev@gmail.com" ||
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid))
      );
    }

    // --- القواعد الأساسية ---

    // 🏆 MASTER OVERRIDE - المسؤولين لهم صلاحيات كاملة
    match /{allPaths=**} {
      allow read, write: if isAdmin();
    }

    // --- القواعد العامة للطلاب (متاحة لجميع المسجلين) ---

    match /settings/global {
      allow read: if isSignedIn();
    }

    match /labs/{labId} {
      allow read: if isSignedIn();
    }

    match /announcements/{id} {
      allow read: if isSignedIn();
    }

    match /curriculum/{id} {
      allow read: if isSignedIn();
    }

    match /exams/{examId} {
      allow read: if isSignedIn();
      match /questions/{questionId} {
        allow read: if isSignedIn();
      }
    }

    match /courses/{courseId} {
      allow read: if isSignedIn();
      match /lectures/{lectureId} {
        allow read: if isSignedIn();
        match /contents/{contentId} {
           allow get: if isSignedIn();
           allow list: if isSignedIn();
        }
      }
    }

    // --- قواعد بيانات المستخدمين (خصوصية تامة) ---

    match /users/{userId} {
      // السماح بـ read (get & list) للطلاب لعرض الأسماء في لوحة الصدارة
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;

      // السماح بـ read للنتائج لحساب ترتيب لوحة الصدارة
      match /studentExams/{id} { 
        allow read: if isSignedIn(); 
        allow write: if isSignedIn() && request.auth.uid == userId; 
      }
      
      // الحفاظ على خصوصية المحفظة والإشعارات
      match /studentCourses/{id} { allow read, write: if isSignedIn() && request.auth.uid == userId; }
      match /depositRequests/{id} { allow read, write: if isSignedIn() && request.auth.uid == userId; }
      match /notifications/{id} { allow read, write: if isSignedIn() && request.auth.uid == userId; }
      
      match /studentCourses/{courseId}/progress/{contentId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // السماح باستعلامات المجموعات (collectionGroup) - ضروري للمسؤول ولوحة الصدارة
    match /{allPaths=**}/studentExams/{id} {
      allow read: if isSignedIn();
    }
    
    match /{allPaths=**}/studentCourses/{id} {
      allow read: if isAdmin();
    }

    match /roles_admin/{userId} {
      allow read: if isSignedIn();
    }
  }
}