rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- الدوال المساعدة (Helper Functions) ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == "70vVkvBj0IQIwbxwdPaEAOj6LSu2" || 
        request.auth.token.email == "mhmdsulimn.dev@gmail.com" ||
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid))
      );
    }

    // 🏆 MASTER OVERRIDE - المسؤولين لهم صلاحيات كاملة
    match /{allPaths=**} {
      allow read, write: if isAdmin();
    }

    // --- القواعد العامة (متاحة لجميع المسجلين) ---

    match /settings/global {
      allow read: if isSignedIn();
    }

    match /labs/{labId} {
      allow read: if isSignedIn();
    }

    match /announcements/{id} {
      allow read: if isSignedIn();
    }

    match /curriculum/{id} {
      allow read: if isSignedIn();
    }

    match /exams/{examId} {
      allow read: if isSignedIn();
      match /questions/{questionId} {
        allow read: if isSignedIn();
      }
    }

    match /courses/{courseId} {
      allow read: if isSignedIn();
      match /lectures/{lectureId} {
        allow read: if isSignedIn();
        match /contents/{contentId} {
           // الوصول للمحتوى الفعلي يتطلب اشتراك (أو أدمن)
           allow get: if isAdmin() || exists(/databases/$(database)/documents/users/$(request.auth.uid)/studentCourses/$(courseId));
           allow list: if isSignedIn();
        }
      }
    }

    // --- قواعد بيانات المستخدمين (خصوصية تامة) ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow create, update: if isSignedIn() && request.auth.uid == userId;

      match /studentExams/{id} { allow read, write: if isSignedIn() && request.auth.uid == userId; }
      match /studentCourses/{id} { allow read, write: if isSignedIn() && request.auth.uid == userId; }
      match /depositRequests/{id} { allow read, write: if isSignedIn() && request.auth.uid == userId; }
      match /notifications/{id} { allow read, write: if isSignedIn() && request.auth.uid == userId; }
      
      match /studentCourses/{courseId}/progress/{contentId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    match /roles_admin/{userId} {
      allow get: if isSignedIn();
    }
  }
}