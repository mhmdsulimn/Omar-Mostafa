rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- الدوال المساعدة (Helper Functions) ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == "70vVkvBj0IQIwbxwdPaEAOj6LSu2" || 
        request.auth.token.email == "mhmdsulimn.dev@gmail.com" ||
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid))
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // 🏆 MASTER OVERRIDE - الصلاحية القصوى للمسؤولين
    match /{allPaths=**} {
      allow read, write: if isAdmin();
    }

    // --- قواعد البيانات العامة (القراءة للجميع المسجلين) ---

    match /settings/{id} {
      allow read: if isSignedIn();
    }

    match /labs/{labId} {
      allow read: if isSignedIn();
    }

    match /announcements/{id} {
      allow read: if isSignedIn();
    }

    match /curriculum/{id} {
      allow read: if isSignedIn();
    }

    match /exams/{examId} {
      allow read: if isSignedIn();
      match /questions/{questionId} {
        allow read: if isSignedIn();
      }
    }

    match /courses/{courseId} {
      allow read: if isSignedIn();
      match /lectures/{lectureId} {
        allow read: if isSignedIn();
        match /contents/{contentId} {
           // الوصول للمحتوى يتطلب اشتراك (إلا للأدمن)
           allow get: if isAdmin() || exists(/databases/$(database)/documents/users/$(request.auth.uid)/studentCourses/$(courseId));
           allow list: if isSignedIn();
        }
      }
    }

    // --- قواعد بيانات المستخدمين (الخصوصية) ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);

      match /studentExams/{id} { 
        allow read, write: if isOwner(userId); 
      }
      match /studentCourses/{id} { 
        allow read, write: if isOwner(userId); 
      }
      match /depositRequests/{id} { 
        allow read, write: if isOwner(userId); 
      }
      match /notifications/{id} { 
        allow read, write: if isOwner(userId); 
      }
      match /studentCourses/{courseId}/progress/{contentId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /roles_admin/{userId} {
      allow get: if isSignedIn();
    }
    
    // قواعد خاصة بطلبات النظام
    match /platform_reset_requests/{id} { allow read, write: if isAdmin(); }
    match /students_to_delete/{id} { allow read, write: if isAdmin(); }
  }
}